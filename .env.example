# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here-change-this
FLASK_ENV=development

# Database Configuration
DATABASE_URI=sqlite:///instance/mainframe_assistant.db

# OpenAI API Configuration (Optional - for AI fallback)
OPENAI_API_KEY=your-openai-api-key-here

# Tesseract OCR Path (Update based on your installation)
# Windows:
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe
# Linux/Mac:
# TESSERACT_PATH=/usr/bin/tesseract